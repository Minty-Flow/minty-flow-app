#!/usr/bin/env bash
set -Eeuo pipefail

# ─── Package Manager ──────────────────────────────────────────────────────────
PM="${PACKAGE_MANAGER:-pnpm}"
if ! command -v "$PM" >/dev/null 2>&1; then
  for candidate in pnpm npm yarn bun; do
    if command -v "$candidate" >/dev/null 2>&1; then PM="$candidate"; break; fi
  done
fi
command -v "$PM" >/dev/null 2>&1 || { echo "Error: no package manager found." >&2; exit 1; }

# ─── Colors ───────────────────────────────────────────────────────────────────
if [ -t 1 ] && [ -z "${NO_COLOR:-}" ]; then
  GRN='\033[0;32m'; RED='\033[0;31m'; DIM='\033[2m'; RST='\033[0m'
else
  GRN=''; RED=''; DIM=''; RST=''
fi

# ─── State ────────────────────────────────────────────────────────────────────
spinner_pid=""
task_pid=""
log_file=""

# ─── Cleanup ──────────────────────────────────────────────────────────────────
cleanup() {
  [ -n "$spinner_pid" ] && kill "$spinner_pid" 2>/dev/null || true; spinner_pid=""
  [ -n "$task_pid"    ] && kill "$task_pid"    2>/dev/null || true; task_pid=""
  [ -n "$log_file" ] && [ -f "$log_file" ] && rm -f "$log_file"; log_file=""
  printf "\r\033[K\n"
}
trap cleanup INT TERM

# ─── Spinner ──────────────────────────────────────────────────────────────────
start_spinner() {
  local label="$1"
  local frames=('⠋' '⠙' '⠹' '⠸' '⠼' '⠴' '⠦' '⠧' '⠇' '⠏')
  local i=0
  while true; do
    printf "\r  ${DIM}%s  %s${RST}" "${frames[$((i % 10))]}" "$label"
    i=$(( i + 1 ))
    sleep 0.08
  done &
  spinner_pid=$!
  disown "$spinner_pid"
}

stop_spinner() {
  local status="$1" label="$2"
  [ -n "$spinner_pid" ] && kill "$spinner_pid" 2>/dev/null || true
  wait "$spinner_pid" 2>/dev/null || true
  spinner_pid=""
  printf "\r\033[K"
  if [ "$status" -eq 0 ]; then
    printf "  ${GRN}✔${RST}  ${DIM}%s${RST}\n" "$label"
  else
    printf "  ${RED}✘${RST}  ${DIM}%s${RST}\n" "$label"
  fi
}

# ─── Task Runner ──────────────────────────────────────────────────────────────
run_task() {
  local label="$1" cmd="$2"
  log_file="$(mktemp)"

  start_spinner "$label"

  eval "$cmd" >"$log_file" 2>&1 &
  task_pid=$!
  wait "$task_pid"
  local exit_code=$?
  task_pid=""

  if [ "$exit_code" -eq 0 ]; then
    stop_spinner 0 "$label"
    rm -f "$log_file"; log_file=""
  else
    stop_spinner 1 "$label"
    echo
    cat "$log_file"
    rm -f "$log_file"; log_file=""
    exit 1
  fi
}

# ─── Main ─────────────────────────────────────────────────────────────────────
echo
printf "  ${DIM}mintyflow · pre-commit${RST}\n"
echo

run_task "structure"  "$PM run structure"
run_task "lint"       "$PM run lint:fix"

if [ -d .git ]; then
  git add . 2>/dev/null || true
fi

run_task "typecheck"  "$PM run types"

echo
printf "  ${GRN}✔  ready to commit${RST}\n"
echo