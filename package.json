{
  "name": "minty-flow-app",
  "main": "index.ts",
  "version": "0.0.5",
  "scripts": {
    "android": "expo run:android",
    "android:emu": "expo run:android --device Pixel_9_Pro",
    "ios": "expo run:ios",
    "prebuild": "expo prebuild",
    "build": "cd android && ./gradlew bundleRelease assembleRelease",
    "types": "tsc --noEmit",
    "prepare": "husky",
    "lint": "biome check",
    "lint:fix": "biome check --write",
    "lint:fix-unsafe": "biome check --write --unsafe",
    "structure": "node ./scripts/generate-structure.mts",
    "unused-styles": "node ./scripts/find-unused-styles.mts",
    "check-i18n-keys": "node ./scripts/check-missing-i18n-keys.mts",
    "icons:filled": "svgr --out-dir src/components/icons/filled tabler-icons/icons/filled",
    "icons:outline": "svgr --out-dir src/components/icons/outline tabler-icons/icons/outline",
    "icons:sync": "pnpm icons:filled && pnpm icons:outline && node scripts/generate-icon-barrel.mts"
  },
  "dependencies": {
    "@expo/ui": "~57.0.7",
    "@hookform/resolvers": "^5.4.0",
    "@shopify/react-native-skia": "^2.6.2",
    "date-fns": "^4.3.0",
    "expo": "^57.0.7",
    "expo-blur": "~57.0.2",
    "expo-build-properties": "^57.0.6",
    "expo-clipboard": "~57.0.1",
    "expo-constants": "~57.0.6",
    "expo-contacts": "~57.0.2",
    "expo-crypto": "~57.0.1",
    "expo-device": "~57.0.1",
    "expo-document-picker": "~57.0.1",
    "expo-file-system": "^57.0.1",
    "expo-font": "~57.0.1",
    "expo-haptics": "~57.0.1",
    "expo-image": "~57.0.1",
    "expo-image-picker": "^57.0.5",
    "expo-intent-launcher": "^57.0.1",
    "expo-linking": "~57.0.3",
    "expo-local-authentication": "~57.0.1",
    "expo-localization": "~57.0.1",
    "expo-location": "~57.0.5",
    "expo-navigation-bar": "^57.0.2",
    "expo-notifications": "~57.0.6",
    "expo-router": "~57.0.7",
    "expo-sensors": "~57.0.2",
    "expo-splash-screen": "~57.0.4",
    "expo-sqlite": "~57.0.1",
    "expo-system-ui": "~57.0.1",
    "expo-web-browser": "~57.0.1",
    "i18next": "^25.10.10",
    "react": "19.2.3",
    "react-hook-form": "^7.76.1",
    "react-i18next": "^16.6.6",
    "react-native": "0.86.0",
    "react-native-enriched-html": "^1.0.1",
    "react-native-gesture-handler": "~2.32.0",
    "react-native-keyboard-controller": "1.21.9",
    "react-native-mmkv": "^4.3.1",
    "react-native-nitro-modules": "^0.35.7",
    "react-native-pager-view": "^8.0.2",
    "react-native-reanimated": "~4.5.2",
    "react-native-restart": "^0.0.27",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "~4.25.2",
    "react-native-svg": "^15.15.4",
    "react-native-unistyles": "^3.3.0",
    "react-native-webview": "13.16.1",
    "react-native-worklets": "0.10.0",
    "react-native-zip-archive": "^8.0.1",
    "rrule": "^2.8.1",
    "victory-native": "^41.20.3",
    "zod": "^4.4.3",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@babel/plugin-proposal-decorators": "^7.29.7",
    "@biomejs/biome": "^2.4.16",
    "@react-native-community/cli": "latest",
    "@svgr/cli": "^8.1.0",
    "@types/node": "^25.9.1",
    "@types/react": "~19.2.15",
    "babel-preset-expo": "~57.0.3",
    "husky": "^9.1.7",
    "typescript": "^6.0.3"
  },
  "private": true,
  "expo": {
    "doctor": {
      "reactNativeDirectoryCheck": {
        "exclude": [
          "react-native-restart"
        ]
      }
    }
  }
}
