{
  "name": "minty-flow-app",
  "main": "index.ts",
  "version": "0.0.3",
  "scripts": {
    "android": "expo run:android",
    "android:emu": "expo run:android --device Pixel_9_Pro",
    "ios": "expo run:ios",
    "prebuild": "expo prebuild",
    "build": "cd android && ./gradlew bundleRelease assembleRelease",
    "types": "tsc --noEmit",
    "prepare": "husky",
    "lint": "biome check",
    "lint:fix": "biome check --write",
    "lint:fix-unsafe": "biome check --write --unsafe",
    "structure": "node ./scripts/generate-structure.mts",
    "unused-styles": "node ./scripts/find-unused-styles.mts",
    "check-i18n-keys": "node ./scripts/check-missing-i18n-keys.mts",
    "build:icons:filled": "svgr --out-dir src/components/icons/filled src/assets/tabler-icons/filled ",
    "build:icons:outline": "svgr --out-dir src/components/icons/outline src/assets/tabler-icons/outline"
  },
  "dependencies": {
    "@expo/ui": "~56.0.16",
    "@hookform/resolvers": "^5.4.0",
    "@shopify/react-native-skia": "^2.6.2",
    "date-fns": "^4.3.0",
    "expo": "^56.0.9",
    "expo-blur": "~56.0.3",
    "expo-build-properties": "^56.0.17",
    "expo-clipboard": "~56.0.4",
    "expo-constants": "~56.0.17",
    "expo-contacts": "~56.0.8",
    "expo-crypto": "~56.0.4",
    "expo-device": "~56.0.4",
    "expo-document-picker": "~56.0.4",
    "expo-file-system": "^56.0.7",
    "expo-font": "~56.0.5",
    "expo-haptics": "~56.0.3",
    "expo-image": "~56.0.10",
    "expo-image-picker": "^56.0.16",
    "expo-intent-launcher": "^56.0.4",
    "expo-linking": "~56.0.13",
    "expo-local-authentication": "~56.0.4",
    "expo-localization": "~56.0.6",
    "expo-location": "~56.0.16",
    "expo-navigation-bar": "^56.0.3",
    "expo-notifications": "~56.0.16",
    "expo-router": "~56.2.9",
    "expo-sensors": "~56.0.5",
    "expo-splash-screen": "~56.0.10",
    "expo-sqlite": "~56.0.4",
    "expo-system-ui": "~56.0.5",
    "expo-web-browser": "~56.0.5",
    "i18next": "^25.10.10",
    "react": "19.2.3",
    "react-hook-form": "^7.76.1",
    "react-i18next": "^16.6.6",
    "react-native": "0.85.3",
    "react-native-enriched": "^0.4.1",
    "react-native-gesture-handler": "~2.31.2",
    "react-native-keyboard-controller": "1.21.6",
    "react-native-mmkv": "^4.3.1",
    "react-native-nitro-modules": "^0.35.7",
    "react-native-pager-view": "^8.0.1",
    "react-native-reanimated": "~4.3.1",
    "react-native-restart": "^0.0.27",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "~4.25.2",
    "react-native-svg": "^15.15.4",
    "react-native-unistyles": "^3.2.4",
    "react-native-webview": "13.16.1",
    "react-native-worklets": "0.8.3",
    "rrule": "^2.8.1",
    "victory-native": "^41.20.3",
    "zod": "^4.4.3",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@babel/plugin-proposal-decorators": "^7.29.7",
    "@biomejs/biome": "^2.4.16",
    "@react-native-community/cli": "latest",
    "@svgr/cli": "^8.1.0",
    "@types/node": "^25.9.1",
    "@types/react": "~19.2.15",
    "babel-preset-expo": "~56.0.13",
    "husky": "^9.1.7",
    "typescript": "~6.0.3"
  },
  "private": true,
  "expo": {
    "doctor": {
      "reactNativeDirectoryCheck": {
        "exclude": [
          "react-native-restart"
        ]
      }
    }
  }
}
